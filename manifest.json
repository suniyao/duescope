{
  "manifest_version": 3,
  "name": "Gradescope Deadline Tracker",
  "version": "1.0",
  "description": "Shows all your Gradescope deadlines in one unified UI.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.gradescope.com/*",
    "*://gradescope.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.gradescope.com/*",
        "*://gradescope.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ]
}